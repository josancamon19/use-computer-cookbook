# Customer API key for use.computer. Generate one from your reservation at
# https://r.use.computer/r/<reservation-id> (shown once on activation).
USE_COMPUTER_API_KEY=mk_live_...

# Required by AnthropicCUAAgent / IOSAgent.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed if you swap in the matching CUA agent.
OPENAI_API_KEY=
